  "title": "PTE Academic",
  "slug": "pte-academic",
  "content": "<!-- wp:group {\"metadata\":{\"name\":\"About\",\"categories\":[\"featured\"],\"patternName\":\"a8c/about-content-left-with-image-right\"},\"align\":\"full\",\"className\":\"alignfull is-style-section-2\",\"style\":{\"spacing\":{\"margin\":{\"top\":\"0\",\"bottom\":\"0\"},\"padding\":{\"top\":\"var:preset|spacing|40\",\"bottom\":\"var:preset|spacing|40\"}}},\"layout\":{\"type\":\"constrained\",\"justifyContent\":\"center\"}} -->\n<div class=\"wp-block-group alignfull is-style-section-2\" style=\"margin-top:0;margin-bottom:0;padding-top:var(--wp--preset--spacing--40);padding-bottom:var(--wp--preset--spacing--40)\"><!-- wp:columns {\"align\":\"wide\",\"style\":{\"spacing\":{\"blockGap\":{\"top\":\"var:preset|spacing|50\",\"left\":\"var:preset|spacing|40\"},\"padding\":{\"right\":\"var:preset|spacing|40\",\"left\":\"var:preset|spacing|40\"}}},\"backgroundColor\":\"tertiary\"} -->\n<div class=\"wp-block-columns alignwide has-tertiary-background-color has-background\" style=\"padding-right:var(--wp--preset--spacing--40);padding-left:var(--wp--preset--spacing--40)\"><!-- wp:column {\"verticalAlignment\":\"center\",\"style\":{\"spacing\":{\"padding\":{\"right\":\"var:preset|spacing|40\",\"left\":\"var:preset|spacing|40\"}}},\"layout\":{\"type\":\"constrained\",\"contentSize\":\"460px\",\"justifyContent\":\"left\"}} -->\n<div class=\"wp-block-column is-vertically-aligned-center\" style=\"padding-right:var(--wp--preset--spacing--40);padding-left:var(--wp--preset--spacing--40)\"><!-- wp:heading -->\n<h2 class=\"wp-block-heading\">Ready to reach your target PTE score and open doors to study, work, or migration abroad?</h2>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>At English with Arik, our PTE Academic Preparation Program is designed to help you reach your dream score by using proven strategies for each skill — Speaking, Writing, Reading, and Listening — with mock tests, personalised feedback, and real progress every week.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph -->\n<p><em>Live 1-on-1 + Self-study Modules | Mock Tests | Personal Feedback | Free Trial Class</em></p>\n<!-- /wp:paragraph -->\n\n<!-- wp:buttons -->\n<div class=\"wp-block-buttons\"><!-- wp:button -->\n<div class=\"wp-block-button\"><a class=\"wp-block-button__link wp-element-button\" href=\"http://wa.me//6282144223581\">FREE CONSULTATION</a></div>\n<!-- /wp:button --></div>\n<!-- /wp:buttons --></div>\n<!-- /wp:column -->\n\n<!-- wp:column {\"verticalAlignment\":\"bottom\"} -->\n<div class=\"wp-block-column is-vertically-aligned-bottom\"><!-- wp:image {\"lightbox\":{\"enabled\":false},\"id\":1114,\"width\":\"521px\",\"height\":\"auto\",\"scale\":\"cover\",\"sizeSlug\":\"medium\",\"linkDestination\":\"none\",\"style\":{\"color\":{\"duotone\":\"unset\"}}} -->\n<figure class=\"wp-block-image size-medium is-resized\"><img src=\"https://englishwitharik.wordpress.com/wp-content/uploads/2025/10/gemini_generated_image_cnrjcacnrjcacnrj.png?w=300\" alt=\"\" class=\"wp-image-1114\" style=\"object-fit:cover;width:521px;height:auto\" /></figure>\n<!-- /wp:image --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"metadata\":{\"name\":\"Why study with us\",\"categories\":[\"featured\"],\"patternName\":\"a8c/about-15\"},\"align\":\"full\",\"className\":\"alignfull is-style-default\",\"style\":{\"spacing\":{\"margin\":{\"top\":\"0\",\"bottom\":\"0\"},\"padding\":{\"top\":\"var:preset|spacing|60\",\"bottom\":\"var:preset|spacing|60\"}}},\"layout\":{\"type\":\"constrained\",\"justifyContent\":\"center\"}} -->\n<div class=\"wp-block-group alignfull is-style-default\" style=\"margin-top:0;margin-bottom:0;padding-top:var(--wp--preset--spacing--60);padding-bottom:var(--wp--preset--spacing--60)\"><!-- wp:columns {\"align\":\"wide\",\"style\":{\"spacing\":{\"blockGap\":{\"top\":\"var:preset|spacing|50\",\"left\":\"var:preset|spacing|50\"}}}} -->\n<div class=\"wp-block-columns alignwide\"><!-- wp:column {\"verticalAlignment\":\"center\",\"width\":\"50%\",\"style\":{\"spacing\":{\"blockGap\":\"24px\"}}} -->\n<div class=\"wp-block-column is-vertically-aligned-center\" style=\"flex-basis:50%\"><!-- wp:image {\"id\":1118,\"width\":\"564px\",\"height\":\"auto\",\"sizeSlug\":\"medium\",\"linkDestination\":\"none\",\"style\":{\"color\":{\"duotone\":\"unset\"},\"border\":{\"radius\":\"16px\"}}} -->\n<figure class=\"wp-block-image size-medium is-resized has-custom-border\"><img src=\"https://englishwitharik.wordpress.com/wp-content/uploads/2025/10/untitled-design-56.png?w=300\" alt=\"\" class=\"wp-image-1118\" style=\"border-radius:16px;width:564px;height:auto\" /></figure>\n<!-- /wp:image --></div>\n<!-- /wp:column -->\n\n<!-- wp:column {\"verticalAlignment\":\"center\",\"width\":\"50%\"} -->\n<div class=\"wp-block-column is-vertically-aligned-center\" style=\"flex-basis:50%\"><!-- wp:heading -->\n<h2 class=\"wp-block-heading\"><strong>Why Choose English with Arik</strong></h2>\n<!-- /wp:heading -->\n\n<!-- wp:list -->\n<ul class=\"wp-block-list\"><!-- wp:list-item {\"style\":{\"typography\":{\"fontSize\":\"1.25rem\",\"fontStyle\":\"normal\",\"fontWeight\":\"400\"}}} -->\n<li style=\"font-size:1.25rem;font-style:normal;font-weight:400\">Certified PTE Academic Trainer — officially recognised by Pearson English Language Learning (Level 2 Professional).</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item {\"style\":{\"typography\":{\"fontSize\":\"1.25rem\",\"fontStyle\":\"normal\",\"fontWeight\":\"400\"}}} -->\n<li style=\"font-size:1.25rem;font-style:normal;font-weight:400\">Experienced Instructor — guided by <em>I Putu Arik Budiarsana</em>, who has helped students from across Indonesia and Indonesian residents in Australia reach their goals.</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item {\"style\":{\"typography\":{\"fontSize\":\"1.25rem\",\"fontStyle\":\"normal\",\"fontWeight\":\"400\"}}} -->\n<li style=\"font-size:1.25rem;font-style:normal;font-weight:400\">All-in-One Learning — live interactive classes, full recordings, and structured self-study modules.</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item {\"style\":{\"typography\":{\"fontSize\":\"1.25rem\",\"fontStyle\":\"normal\",\"fontWeight\":\"400\"}}} -->\n<li style=\"font-size:1.25rem;font-style:normal;font-weight:400\">Personalised Feedback — detailed corrections and strategies for Writing, Speaking, and integrated-skill tasks.</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item {\"style\":{\"typography\":{\"fontSize\":\"1.25rem\",\"fontStyle\":\"normal\",\"fontWeight\":\"400\"}}} -->\n<li style=\"font-size:1.25rem;font-style:normal;font-weight:400\">Full Support — WhatsApp mentoring, vocabulary and pronunciation guidance, and error analysis throughout your journey.</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item {\"style\":{\"typography\":{\"fontSize\":\"1.25rem\",\"fontStyle\":\"normal\",\"fontWeight\":\"400\"}}} -->\n<li style=\"font-size:1.25rem;font-style:normal;font-weight:400\">Mock Tests — computer-based PTE test simulations and score breakdowns (available upon request).</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item {\"style\":{\"typography\":{\"fontSize\":\"1.25rem\",\"fontStyle\":\"normal\",\"fontWeight\":\"400\"}}} -->\n<li style=\"font-size:1.25rem;font-style:normal;font-weight:400\">Certificate of Completion — optional recognition you can add to your academic or professional portfolio.</li>\n<!-- /wp:list-item --></ul>\n<!-- /wp:list --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"metadata\":{\"name\":\"About\",\"categories\":[\"featured\"],\"patternName\":\"a8c/about-content-left-with-image-right\"},\"align\":\"full\",\"className\":\"alignfull is-style-section-2\",\"style\":{\"spacing\":{\"margin\":{\"top\":\"0\",\"bottom\":\"0\"},\"padding\":{\"top\":\"var:preset|spacing|40\",\"bottom\":\"var:preset|spacing|40\"}}},\"layout\":{\"type\":\"constrained\",\"justifyContent\":\"center\"}} -->\n<div class=\"wp-block-group alignfull is-style-section-2\" style=\"margin-top:0;margin-bottom:0;padding-top:var(--wp--preset--spacing--40);padding-bottom:var(--wp--preset--spacing--40)\"><!-- wp:columns {\"align\":\"wide\",\"style\":{\"spacing\":{\"blockGap\":{\"top\":\"var:preset|spacing|50\",\"left\":\"var:preset|spacing|40\"}}}} -->\n<div class=\"wp-block-columns alignwide\"><!-- wp:column {\"verticalAlignment\":\"center\",\"layout\":{\"type\":\"constrained\",\"contentSize\":\"460px\",\"justifyContent\":\"left\"}} -->\n<div class=\"wp-block-column is-vertically-aligned-center\"><!-- wp:heading -->\n<h2 class=\"wp-block-heading\">What You’ll Get</h2>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p><strong>Every PTE Academic program includes:</strong></p>\n<!-- /wp:paragraph -->\n\n<!-- wp:list -->\n<ul class=\"wp-block-list\"><!-- wp:list-item -->\n<li>Flexible scheduling option including easy rescheduling &amp; cancelation</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Complete study materials &amp; class recordings stored on Google Classroom, available for 3-6 months after the completion of the course.</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Authentic Materials from Pearson.</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Official Scored Practice Test from Pearson (additional fee required)</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Personal feedback &amp; error analysis</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item -->\n<li>WhatsApp support between sessions</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item -->\n<li> Optional certificate of completion</li>\n<!-- /wp:list-item --></ul>\n<!-- /wp:list -->\n\n<!-- wp:buttons -->\n<div class=\"wp-block-buttons\"><!-- wp:button -->\n<div class=\"wp-block-button\"><a class=\"wp-block-button__link wp-element-button\" href=\"http://wa.me//+6282144223581\">TRY THE CLASS NOW</a></div>\n<!-- /wp:button --></div>\n<!-- /wp:buttons --></div>\n<!-- /wp:column -->\n\n<!-- wp:column {\"verticalAlignment\":\"bottom\"} -->\n<div class=\"wp-block-column is-vertically-aligned-bottom\"><!-- wp:image {\"lightbox\":{\"enabled\":false},\"id\":1119,\"aspectRatio\":\"1\",\"scale\":\"cover\",\"sizeSlug\":\"full\",\"linkDestination\":\"none\",\"className\":\"is-style-default\",\"style\":{\"color\":{\"duotone\":\"unset\"}}} -->\n<figure class=\"wp-block-image size-full is-style-default\"><img src=\"https://englishwitharik.wordpress.com/wp-content/uploads/2025/10/untitled-design-57.png\" alt=\"\" class=\"wp-image-1119\" style=\"aspect-ratio:1;object-fit:cover\" /></figure>\n<!-- /wp:image --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"metadata\":{\"name\":\"Pricing\"},\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group\"><!-- wp:heading {\"align\":\"full\"} -->\n<h2 class=\"wp-block-heading alignfull\">Pricing</h2>\n<!-- /wp:heading -->\n\n<!-- wp:columns {\"align\":\"full\",\"style\":{\"border\":{\"radius\":\"15px\"}},\"backgroundColor\":\"tertiary\"} -->\n<div class=\"wp-block-columns alignfull has-tertiary-background-color has-background\" style=\"border-radius:15px\"><!-- wp:column {\"style\":{\"spacing\":{\"padding\":{\"right\":\"0\",\"left\":\"0\",\"top\":\"0\",\"bottom\":\"0\"}}}} -->\n<div class=\"wp-block-column\" style=\"padding-top:0;padding-right:0;padding-bottom:0;padding-left:0\"><!-- wp:paragraph -->\n<p><strong>PTE Academic Preparation</strong></p>\n<!-- /wp:paragraph -->\n\n<!-- wp:table {\"className\":\"is-style-stripes\",\"style\":{\"typography\":{\"fontSize\":\"1rem\"}}} -->\n<figure class=\"wp-block-table is-style-stripes\" style=\"font-size:1rem\"><table class=\"has-fixed-layout\"><thead><tr><th class=\"has-text-align-center\" data-align=\"center\">Duration</th><th class=\"has-text-align-center\" data-align=\"center\">Private</th><th class=\"has-text-align-center\" data-align=\"center\">Semi-Private (2-3 students)</th></tr></thead><tbody><tr><td class=\"has-text-align-center\" data-align=\"center\">8 hours</td><td class=\"has-text-align-center\" data-align=\"center\">Rp 1.200.000</td><td class=\"has-text-align-center\" data-align=\"center\">Rp 720.000</td></tr><tr><td class=\"has-text-align-center\" data-align=\"center\">16 hours</td><td class=\"has-text-align-center\" data-align=\"center\">Rp 2.400.000</td><td class=\"has-text-align-center\" data-align=\"center\">Rp 1.440.000</td></tr><tr><td class=\"has-text-align-center\" data-align=\"center\">24 hours</td><td class=\"has-text-align-center\" data-align=\"center\">Rp 3.600.000</td><td class=\"has-text-align-center\" data-align=\"center\">Rp 2.160.000</td></tr><tr><td class=\"has-text-align-center\" data-align=\"center\">More</td><td class=\"has-text-align-center\" data-align=\"center\">Contact Us</td><td class=\"has-text-align-center\" data-align=\"center\">Contact Us</td></tr></tbody></table></figure>\n<!-- /wp:table --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns -->\n\n<!-- wp:paragraph {\"align\":\"center\"} -->\n<p class=\"has-text-align-center\"><em>All prices include class materials, feedback, and access to recordings.</em></p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"metadata\":{\"name\":\"Testimonial\"},\"align\":\"wide\",\"style\":{\"spacing\":{\"blockGap\":\"var:preset|spacing|60\"}},\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group alignwide\"><!-- wp:group {\"align\":\"wide\",\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\",\"justifyContent\":\"stretch\"}} -->\n<div class=\"wp-block-group alignwide\"><!-- wp:paragraph {\"style\":{\"typography\":{\"textTransform\":\"uppercase\",\"fontSize\":\"0.8rem\",\"letterSpacing\":\"0.03rem\",\"fontStyle\":\"normal\",\"fontWeight\":\"600\"}},\"fontFamily\":\"open-runde\"} -->\n<p class=\"has-open-runde-font-family\" style=\"font-size:0.8rem;font-style:normal;font-weight:600;letter-spacing:0.03rem;text-transform:uppercase\">Testimonials</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:heading {\"level\":1} -->\n<h1 class=\"wp-block-heading\">Our Students Say</h1>\n<!-- /wp:heading --></div>\n<!-- /wp:group -->\n\n<!-- wp:columns {\"align\":\"wide\"} -->\n<div class=\"wp-block-columns alignwide\"><!-- wp:column -->\n<div class=\"wp-block-column\"><!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"var:preset|spacing|50\",\"padding\":{\"top\":\"var:preset|spacing|50\",\"bottom\":\"var:preset|spacing|50\",\"left\":\"var:preset|spacing|50\",\"right\":\"var:preset|spacing|50\"}},\"border\":{\"radius\":\"8px\"}},\"backgroundColor\":\"tertiary\",\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group has-tertiary-background-color has-background\" style=\"border-radius:8px;padding-top:var(--wp--preset--spacing--50);padding-right:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--50);padding-left:var(--wp--preset--spacing--50)\"><!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"var:preset|spacing|30\"}},\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\"}} -->\n<div class=\"wp-block-group\"><!-- wp:image {\"width\":\"24px\",\"aspectRatio\":\"1\",\"scale\":\"cover\",\"sizeSlug\":\"full\",\"linkDestination\":\"none\",\"style\":{\"color\":{\"duotone\":[\"#ffc702\",\"#ffc702\"]}}} -->\n<figure class=\"wp-block-image size-full is-resized\"><img src=\"https://s0.wp.com/wp-content/themes/pub/fixmate/assets/images/speech-marks.png\" alt=\"\" style=\"aspect-ratio:1;object-fit:cover;width:24px\" /></figure>\n<!-- /wp:image -->\n\n<!-- wp:paragraph -->\n<p>I took private PTE Academic lessons with Mr Arik for a month before my test. His step-by-step guidance on speaking and writing templates helped me improve my confidence a lot. I especially liked the personalised feedback and mock test reviews. I achieved my target score for migration. Thank you so much, Mr Arik!</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"var:preset|spacing|40\"}},\"layout\":{\"type\":\"flex\",\"flexWrap\":\"nowrap\"}} -->\n<div class=\"wp-block-group\"><!-- wp:image {\"id\":1125,\"sizeSlug\":\"thumbnail\",\"linkDestination\":\"none\",\"style\":{\"color\":{\"duotone\":\"unset\"}}} -->\n<figure class=\"wp-block-image size-thumbnail\"><img src=\"https://englishwitharik.wordpress.com/wp-content/uploads/2025/10/untitled-design-58.png?w=72\" alt=\"\" class=\"wp-image-1125\" /></figure>\n<!-- /wp:image -->\n\n<!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"0rem\"}},\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\",\"justifyContent\":\"stretch\"}} -->\n<div class=\"wp-block-group\"><!-- wp:paragraph {\"style\":{\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"600\"}},\"fontSize\":\"small\",\"fontFamily\":\"open-runde\"} -->\n<p class=\"has-open-runde-font-family has-small-font-size\" style=\"font-style:normal;font-weight:600\">Nadia Ramadhani</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"fontSize\":\"small\",\"fontFamily\":\"open-runde\"} -->\n<p class=\"has-open-runde-font-family has-small-font-size\">Student, Surabaya</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group --></div>\n<!-- /wp:column -->\n\n<!-- wp:column -->\n<div class=\"wp-block-column\"><!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"var:preset|spacing|50\",\"padding\":{\"top\":\"var:preset|spacing|50\",\"bottom\":\"var:preset|spacing|50\",\"left\":\"var:preset|spacing|50\",\"right\":\"var:preset|spacing|50\"}},\"border\":{\"radius\":\"8px\"}},\"backgroundColor\":\"tertiary\",\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group has-tertiary-background-color has-background\" style=\"border-radius:8px;padding-top:var(--wp--preset--spacing--50);padding-right:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--50);padding-left:var(--wp--preset--spacing--50)\"><!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"var:preset|spacing|30\"}},\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\"}} -->\n<div class=\"wp-block-group\"><!-- wp:image {\"width\":\"24px\",\"aspectRatio\":\"1\",\"scale\":\"cover\",\"sizeSlug\":\"full\",\"linkDestination\":\"none\",\"style\":{\"color\":{\"duotone\":[\"#ffc702\",\"#ffc702\"]}}} -->\n<figure class=\"wp-block-image size-full is-resized\"><img src=\"https://s0.wp.com/wp-content/themes/pub/fixmate/assets/images/speech-marks.png\" alt=\"\" style=\"aspect-ratio:1;object-fit:cover;width:24px\" /></figure>\n<!-- /wp:image -->\n\n<!-- wp:paragraph -->\n<p>“Mr Arik is an amazing trainer! Before joining his class, I struggled with the Reading and Listening parts. His detailed explanations and practice techniques made everything so much clearer. I love how he always encourages me and checks my progress through WhatsApp. </p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"var:preset|spacing|40\"}},\"layout\":{\"type\":\"flex\",\"flexWrap\":\"nowrap\"}} -->\n<div class=\"wp-block-group\"><!-- wp:image {\"id\":1126,\"width\":\"80px\",\"height\":\"80px\",\"scale\":\"cover\",\"sizeSlug\":\"full\",\"linkDestination\":\"none\",\"className\":\"is-style-rounded\",\"style\":{\"color\":{\"duotone\":\"unset\"},\"border\":{\"radius\":\"100px\"}}} -->\n<figure class=\"wp-block-image size-full is-resized has-custom-border is-style-rounded\"><img src=\"https://englishwitharik.wordpress.com/wp-content/uploads/2025/10/untitled-design-59.png\" alt=\"\" class=\"wp-image-1126\" style=\"border-radius:100px;object-fit:cover;width:80px;height:80px\" /></figure>\n<!-- /wp:image -->\n\n<!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"0rem\"}},\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\",\"justifyContent\":\"stretch\"}} -->\n<div class=\"wp-block-group\"><!-- wp:paragraph {\"style\":{\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"600\"}},\"fontSize\":\"small\",\"fontFamily\":\"open-runde\"} -->\n<p class=\"has-open-runde-font-family has-small-font-size\" style=\"font-style:normal;font-weight:600\">Andreas Saputra</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"fontSize\":\"small\",\"fontFamily\":\"open-runde\"} -->\n<p class=\"has-open-runde-font-family has-small-font-size\">Software Engineer, Jakarta</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"metadata\":{\"name\":\"FAQ\"},\"align\":\"wide\",\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group alignwide\"><!-- wp:columns {\"verticalAlignment\":\"top\",\"align\":\"wide\"} -->\n<div class=\"wp-block-columns alignwide are-vertically-aligned-top\"><!-- wp:column {\"verticalAlignment\":\"top\",\"width\":\"25%\"} -->\n<div class=\"wp-block-column is-vertically-aligned-top\" style=\"flex-basis:25%\"><!-- wp:paragraph {\"style\":{\"typography\":{\"textTransform\":\"uppercase\",\"fontSize\":\"0.8rem\",\"letterSpacing\":\"0.03rem\",\"fontStyle\":\"normal\",\"fontWeight\":\"700\"}},\"fontFamily\":\"open-runde\"} -->\n<p class=\"has-open-runde-font-family\" style=\"font-size:0.8rem;font-style:normal;font-weight:700;letter-spacing:0.03rem;text-transform:uppercase\">More about us</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:heading {\"level\":1} -->\n<h1 class=\"wp-block-heading\">Frequently Asked Questions</h1>\n<!-- /wp:heading --></div>\n<!-- /wp:column -->\n\n<!-- wp:column {\"verticalAlignment\":\"top\",\"width\":\"75%\"} -->\n<div class=\"wp-block-column is-vertically-aligned-top\" style=\"flex-basis:75%\"><!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"var:preset|spacing|40\"}},\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\",\"justifyContent\":\"stretch\"}} -->\n<div class=\"wp-block-group\"><!-- wp:group {\"style\":{\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|50\",\"bottom\":\"var:preset|spacing|50\",\"left\":\"var:preset|spacing|50\",\"right\":\"var:preset|spacing|50\"}},\"border\":{\"radius\":\"8px\"}},\"backgroundColor\":\"tertiary\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group has-tertiary-background-color has-background\" style=\"border-radius:8px;padding-top:var(--wp--preset--spacing--50);padding-right:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--50);padding-left:var(--wp--preset--spacing--50)\"><!-- wp:details {\"showContent\":true} -->\n<details class=\"wp-block-details\" open><summary>What makes the PTE Academic course different from other test prep?</summary><!-- wp:paragraph {\"placeholder\":\"Type / to add a hidden block\",\"style\":{\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"400\"}},\"fontSize\":\"small\"} -->\n<p class=\"has-small-font-size\" style=\"font-style:normal;font-weight:400\">Our PTE lessons combine expert human coaching and AI-powered mock tests. You’ll learn how to maximise scores in each  task with feedback based on the real Pearson scoring system.</p>\n<!-- /wp:paragraph --></details>\n<!-- /wp:details --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"style\":{\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|50\",\"bottom\":\"var:preset|spacing|50\",\"left\":\"var:preset|spacing|50\",\"right\":\"var:preset|spacing|50\"}},\"border\":{\"radius\":\"8px\"}},\"backgroundColor\":\"tertiary\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group has-tertiary-background-color has-background\" style=\"border-radius:8px;padding-top:var(--wp--preset--spacing--50);padding-right:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--50);padding-left:var(--wp--preset--spacing--50)\"><!-- wp:details -->\n<details class=\"wp-block-details\"><summary>Who is this course for?</summary><!-- wp:paragraph {\"placeholder\":\"Type / to add a hidden block\",\"style\":{\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"400\"}},\"fontSize\":\"small\"} -->\n<p class=\"has-small-font-size\" style=\"font-style:normal;font-weight:400\">It’s designed for anyone preparing for <strong>study, work, or migration</strong> to English-speaking countries such as Australia, New Zealand, or Canada. Both first-time test takers and repeat candidates are welcome..</p>\n<!-- /wp:paragraph --></details>\n<!-- /wp:details --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"style\":{\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|50\",\"bottom\":\"var:preset|spacing|50\",\"left\":\"var:preset|spacing|50\",\"right\":\"var:preset|spacing|50\"}},\"border\":{\"radius\":\"8px\"}},\"backgroundColor\":\"tertiary\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group has-tertiary-background-color has-background\" style=\"border-radius:8px;padding-top:var(--wp--preset--spacing--50);padding-right:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--50);padding-left:var(--wp--preset--spacing--50)\"><!-- wp:details -->\n<details class=\"wp-block-details\"><summary>Do I need to know my English level before joining?</summary><!-- wp:paragraph {\"placeholder\":\"Type / to add a hidden block\",\"style\":{\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"400\"}},\"fontSize\":\"small\"} -->\n<p class=\"has-small-font-size\" style=\"font-style:normal;font-weight:400\">Not necessarily. You can take a quick <strong>free placement test</strong> or a <strong>PTE diagnostic test</strong> with us. It helps determine your current score range and the right study plan for you.</p>\n<!-- /wp:paragraph --></details>\n<!-- /wp:details --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"style\":{\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|50\",\"bottom\":\"var:preset|spacing|50\",\"left\":\"var:preset|spacing|50\",\"right\":\"var:preset|spacing|50\"}},\"border\":{\"radius\":\"8px\"}},\"backgroundColor\":\"tertiary\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group has-tertiary-background-color has-background\" style=\"border-radius:8px;padding-top:var(--wp--preset--spacing--50);padding-right:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--50);padding-left:var(--wp--preset--spacing--50)\"><!-- wp:details -->\n<details class=\"wp-block-details\"><summary>How long does it usually take to reach my target PTE score?</summary><!-- wp:paragraph {\"placeholder\":\"Type / to add a hidden block\",\"style\":{\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"400\"}},\"fontSize\":\"small\"} -->\n<p class=\"has-small-font-size\" style=\"font-style:normal;font-weight:400\">It depends on your starting level and goal. On average, students aiming for PTE 65+ (equivalent to IELTS 7.0) need at least <strong>24 hours</strong> of structured lessons plus home practice.</p>\n<!-- /wp:paragraph --></details>\n<!-- /wp:details --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"style\":{\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|50\",\"bottom\":\"var:preset|spacing|50\",\"left\":\"var:preset|spacing|50\",\"right\":\"var:preset|spacing|50\"}},\"border\":{\"radius\":\"8px\"}},\"backgroundColor\":\"tertiary\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group has-tertiary-background-color has-background\" style=\"border-radius:8px;padding-top:var(--wp--preset--spacing--50);padding-right:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--50);padding-left:var(--wp--preset--spacing--50)\"><!-- wp:details -->\n<details class=\"wp-block-details\"><summary>What’s included in the course package?</summary><!-- wp:paragraph {\"placeholder\":\"Type / to add a hidden block\",\"style\":{\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"400\"}},\"fontSize\":\"small\"} -->\n<p class=\"has-small-font-size\" style=\"font-style:normal;font-weight:400\">✅ Live 1-on-1 coaching sessions<br>✅ Full digital study materials &amp; recordings<br>✅ AI mock tests with score reports (Paid)<br>✅ Pronunciation &amp; fluency drills<br>✅ Personalised feedback and WhatsApp support</p>\n<!-- /wp:paragraph --></details>\n<!-- /wp:details --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"style\":{\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|50\",\"bottom\":\"var:preset|spacing|50\",\"left\":\"var:preset|spacing|50\",\"right\":\"var:preset|spacing|50\"}},\"border\":{\"radius\":\"8px\"}},\"backgroundColor\":\"tertiary\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group has-tertiary-background-color has-background\" style=\"border-radius:8px;padding-top:var(--wp--preset--spacing--50);padding-right:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--50);padding-left:var(--wp--preset--spacing--50)\"><!-- wp:details -->\n<details class=\"wp-block-details\"><summary>Can I take the course even if I’ve never done PTE before?</summary><!-- wp:paragraph {\"placeholder\":\"Type / to add a hidden block\",\"style\":{\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"400\"}},\"fontSize\":\"small\"} -->\n<p class=\"has-small-font-size\" style=\"font-style:normal;font-weight:400\">Of course. We’ll guide you from the basics of the test format to advanced strategies. Many of our students start with zero experience and achieve their target score.</p>\n<!-- /wp:paragraph --></details>\n<!-- /wp:details --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns --></div>\n<!-- /wp:group -->",
